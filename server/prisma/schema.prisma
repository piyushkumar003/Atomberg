generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum GoalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  RETURNED
  LOCKED
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
}

enum UOMType {
  NUMBER
  PERCENTAGE
  CURRENCY
}

enum CycleType {
  ANNUAL
  QUARTERLY
}

enum CheckInStatus {
  NOT_STARTED
  ON_TRACK
  COMPLETED
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  password_hash String
  role          Role     @default(EMPLOYEE)
  employee_code String?  @unique
  department    String?
  manager_id    String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  manager      User?          @relation("ManagerToEmployee", fields: [manager_id], references: [id])
  employees    User[]         @relation("ManagerToEmployee")
  goals        Goal[]
  refreshTokens RefreshToken[]
  approvals    GoalApproval[] @relation("ManagerApprovals")
}

model RefreshToken {
  id         String   @id @default(uuid())
  token_hash String   @unique
  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  revoked_at DateTime?
  expires_at DateTime
  created_at DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entity     String
  entity_id  String
  actor_id   String
  details    Json?
  ip_address String?
  created_at DateTime @default(now())
}

model GoalCycle {
  id         String   @id @default(uuid())
  name       String
  quarter    Int
  start_date DateTime
  end_date   DateTime
  is_active  Boolean  @default(true)
  cycle_type CycleType @default(QUARTERLY)
  created_at DateTime @default(now())
  goals      Goal[]
}

model Goal {
  id                String   @id @default(uuid())
  employee_id       String
  cycle_id          String
  title             String
  description       String?
  thrust_area       String
  weightage         Int
  uom_type          UOMType  @default(PERCENTAGE)
  target_value      Float
  status            GoalStatus @default(DRAFT)
  submission_status SubmissionStatus @default(PENDING)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  deleted_at        DateTime?

  employee User      @relation(fields: [employee_id], references: [id])
  cycle    GoalCycle @relation(fields: [cycle_id], references: [id])
  approvals GoalApproval[]
  checkins  QuarterlyUpdate[]
}

model SharedGoalLink {
  id         String   @id @default(uuid())
  goal_id    String
  token      String   @unique
  expires_at DateTime
  created_at DateTime @default(now())
}

model GoalApproval {
  id           String   @id @default(uuid())
  goal_id      String
  manager_id   String
  status       GoalStatus @default(SUBMITTED)
  submitted_at DateTime   @default(now())
  reviewed_at  DateTime?
  approved_at  DateTime?
  returned_at  DateTime?
  
  goal     Goal              @relation(fields: [goal_id], references: [id])
  manager  User              @relation("ManagerApprovals", fields: [manager_id], references: [id])
  comments ApprovalComment[]
}

model ApprovalComment {
  id          String   @id @default(uuid())
  approval_id String
  author_id   String
  content     String
  created_at  DateTime @default(now())

  approval GoalApproval @relation(fields: [approval_id], references: [id])
}

model QuarterlyUpdate {
  id                 String   @id @default(uuid())
  goal_id            String
  quarter            Int
  planned_target     Float
  actual_achievement Float
  progress_score     Float
  status             CheckInStatus @default(ON_TRACK)
  comment            String?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  goal Goal @relation(fields: [goal_id], references: [id])
}
